{
  "name": "fd-claims-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm:dev:api\"",
    "dev:client": "vite",
    "dev:api": "wrangler d1 migrations apply FD_CLAIMS_DB --local --persist-to .wrangler/state && wrangler pages dev ./public --proxy 5174 --port 3002 --d1 FD_CLAIMS_DB --kv FD_CLAIMS_USERS --kv FD_LIGHT_STATE --r2 FD_PROJECT_FILES --persist-to .wrangler/state --log-level warn",
    "dev:server": "npm run dev:api",
    "migrate:local": "wrangler d1 migrations apply FD_CLAIMS_DB --local --persist-to .wrangler/state",
    "migrate:remote": "wrangler d1 migrations apply FD_CLAIMS_DB --remote",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@notionhq/client": "^5.11.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
